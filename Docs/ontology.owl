    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/PEC2/med#affectsDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2/med#affectsDeviceType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2/med#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2/med#DeviceType"/>
        <rdfs:comment xml:lang="en">Links a risk to a device type.</rdfs:comment>
        <rdfs:label xml:lang="en">affects device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/PEC2/med#hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/PEC2/med#hasDeviceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/PEC2/med#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/PEC2/med#DeviceType"/>
        <rdfs:comment xml:lang="en">Links a device to a device type.</rdfs:comment>
        <rdfs:label xml:lang="en">has device type</rdfs:label>
    </owl:ObjectProperty>
    


