<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uoc.edu/PEC2/med#"
     xml:base="http://www.uoc.edu/PEC2/med"
     xmlns:med="http://www.uoc.edu/PEC2/med#"
     xmlns:mod="https://w3id.org/mod#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://www.uoc.edu/PEC2/med">
        <terms:description xml:lang="en">Ontology for the medical device catalog</terms:description>
        <terms:title xml:lang="en">Medical Catalog Ontology</terms:title>
        <vann:preferredNamespacePrefix>med</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:resource="http://www.uoc.edu/PEC2/med#"/>
        <rdfs:comment xml:lang="en">Ontology for devices, incidents, risks, manufacturers and FSCAs.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Catalog Ontology</rdfs:label>
        <owl:versionInfo>1.2</owl:versionInfo>
        <mod:createdWith rdf:resource="https://chowlk.linkeddata.es/"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespacePrefix -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespacePrefix"/>
    


    <!-- http://purl.org/vocab/vann/preferredNamespaceUri -->


    <owl:AnnotationProperty rdf:about="http://purl.org/vocab/vann/preferredNamespaceUri"/>
    


    <!-- http://www.w3.org/2002/07/owl#versionInfo -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2002/07/owl#versionInfo"/>
    


    <!-- https://w3id.org/mod#createdWith -->


    <owl:AnnotationProperty rdf:about="https://w3id.org/mod#createdWith"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


